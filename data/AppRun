#!/bin/sh
HERE="$(dirname "$(readlink -f "$0")")"
BUNDLED_LIB="${HERE}/usr/lib"

# ── Detect system GTK4 + libadwaita ───────────────────
# Both must be present and from the same stack.
# If the system has GTK4 but not libadwaita (or vice versa),
# falling back to bundled mode avoids version mismatches
# that cause CSS parse errors and transparent GUIs.
SYSTEM_GTK4=0
SYSTEM_LIBADWAITA=0
for dir in /usr/lib/x86_64-linux-gnu /usr/lib64 /usr/lib /usr/local/lib; do
  if [ -f "${dir}/libgtk-4.so.1" ]; then
    SYSTEM_GTK4=1
  fi
  if [ -f "${dir}/libadwaita-1.so.0" ]; then
    SYSTEM_LIBADWAITA=1
  fi
done
USE_SYSTEM=0
if [ "$SYSTEM_GTK4" = "1" ] && [ "$SYSTEM_LIBADWAITA" = "1" ]; then
  USE_SYSTEM=1
fi

# Allow user override
if [ "${QR_STUDIO_SYSTEM_LIBS}" = "1" ]; then
  USE_SYSTEM=1
elif [ "${QR_STUDIO_BUNDLED_LIBS}" = "1" ]; then
  USE_SYSTEM=0
fi

if [ "$USE_SYSTEM" = "1" ]; then
  # ── System mode ────────────────────────────────
  # System libs first, bundled as fallback.
  # Use system GIO modules, gdk-pixbuf, etc.
  export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:+${LD_LIBRARY_PATH}:}${BUNDLED_LIB}"
  export GSETTINGS_SCHEMA_DIR="${HERE}/usr/share/glib-2.0/schemas${GSETTINGS_SCHEMA_DIR:+:${GSETTINGS_SCHEMA_DIR}}"
  export XDG_DATA_DIRS="${HERE}/usr/share${XDG_DATA_DIRS:+:${XDG_DATA_DIRS}}"
else
  # ── Bundled mode (portable) ────────────────────
  # Bundled libs first, system as fallback.
  # Use bundled modules to ensure version consistency.
  export LD_LIBRARY_PATH="${BUNDLED_LIB}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
  export GDK_PIXBUF_MODULEDIR="${BUNDLED_LIB}/gdk-pixbuf-2.0/2.10.0/loaders"
  export GDK_PIXBUF_MODULE_FILE="${BUNDLED_LIB}/gdk-pixbuf-2.0/2.10.0/loaders.cache"
  export GIO_MODULE_DIR="${BUNDLED_LIB}/gio/modules"
  export GTK_PATH="${BUNDLED_LIB}/gtk-4.0"
  export GSETTINGS_SCHEMA_DIR="${HERE}/usr/share/glib-2.0/schemas${GSETTINGS_SCHEMA_DIR:+:${GSETTINGS_SCHEMA_DIR}}"
  export XDG_DATA_DIRS="${HERE}/usr/share${XDG_DATA_DIRS:+:${XDG_DATA_DIRS}}"
fi

exec "${HERE}/usr/bin/qr_studio" "$@"
